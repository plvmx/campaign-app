# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Claude Code project settings (may contain secrets like GH_TOKEN)
.claude/settings.json
.claude/settings.local.json

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# database backups (never commit)
backup-*.sql.gz
*.sql.gz
!scripts/**/*.sql

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# image files (except those in public/slides which are needed)
*.jpeg
*.jpg
!public/slides/*.jpg

# generated documentation PDF (regenerate locally with Chrome --print-to-pdf)
TECHNICAL_DOCS.pdf
TECHNICAL_DOCS.html
